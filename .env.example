# CORS
CORS_ORIGIN=http://localhost:5173

# Server
PORT=3000
DB_PATH=/data/rtc.db

# Tuning (defaults shown)
# HEARTBEAT_TIMEOUT_MS=30000
# RECONNECT_WINDOW_MS=30000
# MAX_ROOM_DURATION_MS=3600000
# USERSIG_TTL_SEC=3600
